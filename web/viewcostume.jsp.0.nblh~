<%@page contentType="text/html" import="java.sql.*" pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
    <head>
        <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
        <title>JSP Page</title>
        <script>
            function funct()
            {
                var id = document.form1.select.value;
                window.location.replace("viewbyid.jsp?select="+id);
            }
        </script>
    </head>
    <body>
        <a href="home.jsp">Home</a>
        <%
            String ccd="";
            Class.forName("com.mysql.jdbc.Driver");
            Connection con1 = DriverManager.getConnection("jdbc:mysql://localhost:3306/reg", "root", "");
            Statement st1 = con1.createStatement();
            String a = "";
            String b = "";
            String c = "";
            try{
                String id = request.getParameter("select");
                ccd=id;
                ResultSet rst1 = st1.executeQuery("select * from staff where id='"+id+"'");
                while(rst1.next())
                {
                    a = rst1.getString("sname");
                    b = rst1.getString("sdept");
                    c = rst1.getString("sphone");
                }
            }
            catch(Exception e1)
            {
                e1.printStackTrace();
            }
        %>
        <h2>Select ID</h2> : 
                    <label><select name="select" size="1"
                                                                     onchange="funct(this.value)">
                                <option><%=ccd%></option>
                                <%
                                Class.forName("com.mysql.jdbc.Driver").newInstance();
                                Connection con = DriverManager.getConnection("jdbc:mysql://localhost:3306/reg", "root", "");
                                Statement st = con.createStatement();
                                ResultSet rs = st.executeQuery("select id from staff");
                                int count=0;
                                while(rs.next())
                                {
                                    %>
                                    <option><%=rs.getString("id")%></option>
                                    <%
                                }
                                %>
                            </select>
                            <br>
                       
        <form name="form1" method="post" action="viewbyid.jsp">
            <table align="center" width="509" height="267">
                <tr bgcolor="#66CCFF">
                    <td height="63" colspan="2" align="center" bgcolor="#9999CC">View Staff Details</td>
                </tr>
                
                <tr>
                    <td bgcolor="#9999CC">Name</td>
                    <td bgcolor="#9999CC"><label>
                            <input type="text" name="name" value="<%=a%>"></label></td>
                </tr>
                <tr>
                    <td bgcolor="#9999CC">Department</td>
                    <td bgcolor="#9999CC"><label>
                            <input type="text" name="dept" value="<%=b%>"></label></td>
                </tr>
                <tr>
                    <td bgcolor="#9999CC">Phone</td>
                    <td bgcolor="#9999CC"><label>
                            <input type="text" name="phone" value="<%=c%>"></label></td>
                </tr>
                <tr><td align="center"></td></tr>
            </table>
        </form>
    </body>
</html>
